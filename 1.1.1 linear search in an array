#include<stdio.h>
int main(){
	int n, key, i, found = 0, pos = -1;

	if(scanf("%d", &n) != 1) return 0;
	int arr[n];
	for (i = 0; i < n; i++) {
		scanf("%d", &arr[i]);
	}
	scanf("%d", &key);
	
	for (i = 0; i < n; i++) {
		if (arr[i] == key){
			found = 1;
			pos = i;
			break;
		}
		}
		if (found) {
			printf("found at position %d\n", pos);
			
		} else {
			printf("%d not found\n", key);
			
		}
	
return 0;
}
