struct node {
    int data;
    struct node* next;
};

typedef struct node* NODE;

NODE createNode(int x) {
    NODE temp;
    temp = (NODE)malloc(sizeof(struct node));
    
    if (temp == NULL) {
        printf("Memory allocation failed\n");
        return NULL;
    }
    
    temp->data = x;
    temp->next = NULL;
    return temp;

    
    
    
    
}

NODE addNode(NODE first, int x) {
    NODE temp, cur;
    
    temp = createNode(x);
    if (temp == NULL)
        return first;

    // If list is empty
    if (first == NULL) {
        return temp;
    }

    // Traverse to last node
    cur = first;
    while (cur->next != NULL) {
        cur = cur->next;
    }

    cur->next = temp;
    return first;

    
    
    
    
}

NODE concatenate(NODE t1, NODE t2) {
     NODE cur;

    // If first list is empty
    if (t1 == NULL)
        return t2;

    // If second list is empty
    if (t2 == NULL)
        return t1;

    // Traverse to end of first list
    cur = t1;
    while (cur->next != NULL) {
        cur = cur->next;
    }

    
    cur->next = t2;

    return t1;

    
    
    
    
}

void displayList(NODE first) {
     NODE cur = first;

    if (cur == NULL) {
        printf("NULL\n");
        return;
    }

    while (cur != NULL) {
        printf("%d --> ", cur->data);
        cur = cur->next;
    }

    printf("NULL\n");

    
    
    
    
}
